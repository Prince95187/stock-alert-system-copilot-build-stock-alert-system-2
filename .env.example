# ── Web server ────────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
DEBUG=false

# ── Rule Engine ───────────────────────────────────────────────────────────────
ENGINE_SHARD_COUNT=8
PERCENTAGE_WINDOW_SECONDS=3600
ALERT_COOLDOWN_SECONDS=300

# ── Ingestion ─────────────────────────────────────────────────────────────────
# URI of the upstream WebSocket price feed.
# Leave unset to use the built-in price simulator (demo mode).
WS_FEED_URI=ws://localhost:8765
RATE_LIMIT_TICKS_PER_SECOND=500

# ── Notification ──────────────────────────────────────────────────────────────
NOTIFICATION_QUEUE_SIZE=1000
MOCK_EMAIL_FROM=alerts@stockalert.dev
MOCK_EMAIL_TO=user@example.com
